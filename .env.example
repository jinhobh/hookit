# Example environment configuration.
# Copy to `.env` for local development: `cp .env.example .env`
# NEVER commit a real `.env` file or real secrets.

# --- Application ---
APP_NAME=reliable-webhook-platform
APP_ENV=local
DEBUG=true

# --- Database ---
# psycopg v3 driver. Matches the docker-compose `postgres` service defaults.
DATABASE_URL=postgresql+psycopg://webhook:webhook@localhost:5432/webhook

# --- Delivery / worker defaults (placeholders for later phases) ---
DELIVERY_TIMEOUT_SECONDS=10
MAX_DELIVERY_ATTEMPTS=6
