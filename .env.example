# Example environment configuration.
# Copy to `.env` for local development: `cp .env.example .env`
# NEVER commit a real `.env` file or real secrets.

# --- Application ---
APP_NAME=reliable-webhook-platform
APP_ENV=local
DEBUG=true

# --- Database ---
# psycopg v3 driver. Matches the docker-compose `postgres` service defaults.
DATABASE_URL=postgresql+psycopg://webhook:webhook@localhost:5432/webhook

# --- Delivery / worker defaults ---
DELIVERY_TIMEOUT_SECONDS=10
MAX_DELIVERY_ATTEMPTS=6
WORKER_BATCH_SIZE=10           # max deliveries claimed per worker loop tick
WORKER_LEASE_SECONDS=60        # lease duration before a crashed worker's claims expire
MAX_EVENT_PAYLOAD_BYTES=65536  # maximum JSON payload size for POST /events

# --- Live simulation demo ---
# Must be a hostname (not an IP literal) reachable from the worker process —
# used to build the self-referential receiver URL for POST /simulate/run.
PUBLIC_BASE_URL=http://localhost:8000
