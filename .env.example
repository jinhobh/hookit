# Example environment configuration.
# Copy to `.env` for local development: `cp .env.example .env`
# NEVER commit a real `.env` file or real secrets.

# --- Application ---
APP_NAME=reliable-webhook-platform
APP_ENV=local
DEBUG=true

# --- Database ---
# psycopg v3 driver. Matches the docker-compose `postgres` service defaults.
DATABASE_URL=postgresql+psycopg://webhook:webhook@localhost:5432/webhook

# --- Delivery / worker defaults ---
DELIVERY_TIMEOUT_SECONDS=10
MAX_DELIVERY_ATTEMPTS=6
WORKER_BATCH_SIZE=10           # max deliveries claimed per worker loop tick
WORKER_LEASE_SECONDS=60        # lease duration before a crashed worker's claims expire
MAX_EVENT_PAYLOAD_BYTES=65536  # maximum JSON payload size for POST /events

# --- Live showcase demo ---
# Must be a hostname (not an IP literal) reachable from the worker process —
# used to build the controllable receiver URL for the /showcase/* routes.
PUBLIC_BASE_URL=http://localhost:8000

# Stable name of the shared, seeded showcase project (see app/seed_showcase.py).
SHOWCASE_PROJECT_NAME=__showcase__
# Shared API key for the showcase project (SECRET). The seeder stores its hash so
# the `producer` service can authenticate with this same value. Leave blank to
# disable seeding the key.
SHOWCASE_API_KEY=
# Real Discord webhook URL the showcase delivers price alerts to (SECRET). Leave
# blank to disable the Discord endpoint (the reliability demo still works).
SHOWCASE_DISCORD_WEBHOOK_URL=
# Internal base URL of the producer control server; POST /showcase/burst proxies
# to '{PRODUCER_BASE_URL}/burst'.
PRODUCER_BASE_URL=http://localhost:8100
# Public Discord server + channel ids for the dashboard's embedded live channel
# widget (non-secret).
DISCORD_WIDGET_SERVER_ID=
DISCORD_WIDGET_CHANNEL_ID=

# --- Live showcase idle scale-down ---
# Stops the producer/worker Fly machines after no real dashboard visitor for a
# while, and wakes them on the next visit. Leave both blank to disable (the
# default — safe for local dev, where there's no Fly Machines API to call).
FLY_API_TOKEN=
# FLY_APP_NAME is normally left unset here — Fly injects it automatically into
# every machine in production. Only set it if running this outside Fly.
# FLY_APP_NAME=
# VISITOR_IDLE_MINUTES=10
# IDLE_WATCHDOG_INTERVAL_SECONDS=60

# --- Producer service (python -m producer) ---
# The separate producer reads these (see producer/README.md). PLATFORM_API_KEY
# must equal SHOWCASE_API_KEY above so it can authenticate.
PLATFORM_API_URL=http://localhost:8000
PLATFORM_API_KEY=
# PRICE_API_URL=https://api.coinbase.com/v2/prices
# SYMBOLS=BTC-USD,ETH-USD,SOL-USD,DOGE-USD
# POLL_INTERVAL_SECONDS=4
# ALERT_THRESHOLD_PCT=0.5
# BURST_COUNT=20
# CONTROL_PORT=8100
